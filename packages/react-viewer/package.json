{
  "name": "@flowajs/react-viewer",
  "version": "0.1.2",
  "description": "React components for rendering flowa pipeline outputs: citation-grounded Markdown, PDF viewer with bbox highlights, triage workspace.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/populationgenomics/flowa.git",
    "directory": "packages/react-viewer"
  },
  "homepage": "https://github.com/populationgenomics/flowa#readme",
  "bugs": {
    "url": "https://github.com/populationgenomics/flowa/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "build:js:watch": "tsup --watch",
    "build:css:watch": "tailwindcss -i src/styles.css -o dist/styles.css --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react-markdown": "10.1.0",
    "react-pdf": "9.2.1",
    "remark-gfm": "4.0.1",
    "unist-util-visit": "5.1.0"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tabler/icons-react": "^3.0.0",
    "ai": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "3.0.193",
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@tabler/icons-react": "3.44.0",
    "@testing-library/react": "16.3.2",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "ai": "6.0.191",
    "autoprefixer": "10.5.0",
    "happy-dom": "20.9.0",
    "postcss": "8.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17",
    "tsup": "8.5.1",
    "typescript": "5.7.3",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "zustand": "5.0.14"
  }
}
