{
  "name": "@flowajs/react-viewer",
  "version": "0.0.6",
  "description": "React components for rendering flowa pipeline outputs: citation-grounded Markdown, PDF viewer with bbox highlights, triage workspace.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/populationgenomics/flowa.git",
    "directory": "packages/react-viewer"
  },
  "homepage": "https://github.com/populationgenomics/flowa#readme",
  "bugs": {
    "url": "https://github.com/populationgenomics/flowa/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "3.4.3",
    "html-react-parser": "5.2.2",
    "marked": "16.4.2",
    "react-pdf": "9.2.1"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tabler/icons-react": "^3.0.0",
    "ai": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "3.0.184",
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@tabler/icons-react": "3.44.0",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "ai": "6.0.182",
    "happy-dom": "20.9.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsup": "8.5.1",
    "typescript": "5.7.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "zustand": "4.5.6"
  }
}
