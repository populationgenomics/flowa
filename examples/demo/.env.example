# Required: pick exactly one provider block by uncommenting it.
# LLM_MODEL takes the form <provider>:<model>; chat-service and the future
# pipeline runner consume the same value. Provider creds are read by each
# SDK directly via standard env vars.

# --- anthropic ---
# LLM_MODEL=anthropic:claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# --- bedrock ---
# LLM_MODEL=bedrock:au.anthropic.claude-sonnet-4-6
# BEDROCK_INFERENCE_PROFILE=arn:aws:bedrock:...   # optional, for cost attribution
# AWS_REGION=ap-southeast-2
# AWS_PROFILE=...                                 # or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY

# --- google-gla (Gemini API, key-based) ---
# LLM_MODEL=google-gla:gemini-2.5-pro
# GOOGLE_API_KEY=...

# --- google-vertex (Vertex AI, GCP project) ---
# LLM_MODEL=google-vertex:gemini-2.5-pro
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# GOOGLE_VERTEX_PROJECT=...
# GOOGLE_VERTEX_LOCATION=us-central1

# --- openai ---
# LLM_MODEL=openai:gpt-5
# OPENAI_API_KEY=sk-...

# Optional: override the default storage root for fixtures + sessions.
# DEMO_DATA_DIR=./demo-data

# Optional: override default ports if 7700 / 7701 are in use locally.
# DEMO_NEXT_PORT=7700
# CHAT_SERVICE_PORT=7701
